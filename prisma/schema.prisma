generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OtpPurpose {
  CUSTOMER_SIGNUP
  VENDOR_SIGNUP
  LOGIN
  PASSWORD_RESET
}

enum IdempotencyStatus {
  IN_PROGRESS
  SUCCEEDED
  FAILED
}

enum VendorStatus {
  ONBOARDING
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum VendorOnboardingStep {
  ACCOUNT_SETUP
  STORE_INFORMATION
  IDENTITY_VERIFICATION
  ADDRESS_CONTACT
  PAYOUT_INFORMATION
  AGREEMENTS
  SUBMITTED
}

enum BusinessType {
  INDIVIDUAL
  REGISTERED_BUSINESS
}

enum IndustryType {
  BAKERY
  CLOTHING
  ELECTRONICS
  FLORISTS
  DRIED_FRUITS
  CARPETS
  FOOD_BEVERAGES
  JEWELRY
  HEALTH_BEAUTY
  HOME_FURNITURE
  SPORTS_OUTDOORS
  BOOKS_STATIONERY
  TOYS_GAMES
  AUTOMOTIVE
  HANDICRAFTS
  AGRICULTURE
  OTHER
}

enum SellerType {
  PLATFORM
  THIRD_PARTY
}

enum KycDocumentType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutMethodType {
  BANK
  STRIPE
}

enum ProductApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum OrderStatus {
  CREATED
  PAID
  PARTIALLY_FULFILLED
  FULFILLED
  COMPLETED
  CANCELLED
}

enum OrderCancelledByRole {
  CUSTOMER
  VENDOR
  ADMIN
  SYSTEM
}

enum VendorOrderStatus {
  NEW
  PREPARING
  INBOUND_SHIPPED
  RECEIVED_AT_WAREHOUSE
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InboundShipmentStatus {
  PENDING_SHIPMENT
  INBOUND_SHIPPED
  RECEIVED
}

enum ConsolidationBatchStatus {
  OPEN
  PARTIALLY_RECEIVED
  READY_TO_CONSOLIDATE
  CONSOLIDATED
  OUTBOUND_SHIPPED
  DELIVERED
  CANCELLED
}

enum OutboundShipmentStatus {
  CONSOLIDATED
  OUTBOUND_SHIPPED
  DELIVERED
}

enum PaymentProvider {
  STRIPE
}

enum PaymentTransactionStatus {
  SUCCEEDED
  FAILED
}

enum LedgerBucket {
  HOLD
  AVAILABLE
}

enum VendorLedgerEntryType {
  SALE_HOLD
  HOLD_RELEASE_DEBIT
  HOLD_RELEASE_CREDIT
  PAYOUT_DEBIT
  REFUND_DEBIT_HOLD
  REFUND_DEBIT_AVAILABLE
}

enum PayoutStatus {
  ON_HOLD
  READY
  SENT
  FAILED
}

enum RefundCaseStatus {
  REQUESTED
  WAITING_VENDOR
  ESCALATED_ADMIN
  RESOLVED
}

enum RefundDecisionType {
  APPROVE
  REJECT
  PARTIAL
}

enum MembershipInvoiceStatus {
  PENDING
  PAID
  WAIVED
  VOID
}

enum VendorSubscriptionStatus {
  TRIAL
  ACTIVE
  FAILED
  SUSPENDED
}

enum DeliveryMethod {
  PICKUP
  EXPRESS
  STANDARD
}

enum DeliveryRuleScope {
  GLOBAL
  COUNTRY
  VENDOR
}

enum DeliveryPriceModel {
  FLAT
  PER_KM
  FREE_ABOVE
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model User {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  fullName          String
  email             String            @unique
  phone             String            @unique
  passwordHash      String
  role              Role
  status            UserStatus        @default(PENDING)
  isEmailVerified   Boolean           @default(false)
  isPhoneVerified   Boolean           @default(false)
  lastLoginAt       DateTime?
  preferredCurrency String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          Session[]
  auditLogs         AuditLog[]
  vendorProfile     VendorProfile?
  customerAddresses CustomerAddress[]
  cart              Cart?
  orders            Order[]
  refundCases       RefundCase[]
  caseMessages      CaseMessage[]
  giftRequests      GiftRequest[]
  hawalaTransfers   HawalaTransfer[]
  productReviews    ProductReview[]
}

model Session {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @db.ObjectId
  refreshHash String
  status      SessionStatus @default(ACTIVE)
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

model OtpCode {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  phone      String?
  email      String?
  purpose    OtpPurpose
  codeHash   String
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([phone, purpose])
  @@index([email, purpose])
  @@index([expiresAt])
}

model IdempotencyKey {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  key          String            @unique
  scope        String
  requestHash  String
  status       IdempotencyStatus @default(IN_PROGRESS)
  responseCode Int?
  responseBody Json?
  resourceType String?
  resourceId   String?
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([scope, status])
  @@index([expiresAt])
}

model CheckoutSnapshot {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  paymentIntentId       String   @unique
  source                String
  userId                String?  @db.ObjectId
  checkoutContextHash   String
  checkoutGuestEmailHash String?
  snapshot              Json
  orderId               String?  @db.ObjectId
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderId])
  @@index([source, createdAt])
}

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  actorUserId String?  @db.ObjectId
  actorRole   Role?
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model VendorProfile {
  id                             String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId                         String                     @unique @db.ObjectId
  storeName                      String?
  storeSlug                      String?
  businessType                   BusinessType?
  industryType                   IndustryType?
  sellerType                     SellerType                 @default(THIRD_PARTY)
  logoUrl                        String?
  description                    String?
  onboardingStep                 VendorOnboardingStep       @default(ACCOUNT_SETUP)
  status                         VendorStatus               @default(ONBOARDING)
  submittedAt                    DateTime?
  approvedAt                     DateTime?
  approvedByUserId               String?                    @db.ObjectId
  rejectedAt                     DateTime?
  rejectionReason                String?
  suspendedAt                    DateTime?
  suspensionReason               String?
  stripeCustomerId               String?
  stripeSubscriptionId           String?
  stripeDefaultPaymentMethodId   String?
  subscriptionStatus             VendorSubscriptionStatus   @default(TRIAL)
  subscriptionTrialEndsAt        DateTime?
  subscriptionCurrentPeriodStart DateTime?
  subscriptionCurrentPeriodEnd   DateTime?
  subscriptionLastPaymentAt      DateTime?
  subscriptionNextBillingAt      DateTime?
  subscriptionGracePeriodEndsAt  DateTime?
  subscriptionFailedPaymentCount Int                        @default(0)
  subscriptionFailedAt           DateTime?
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  user                           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycDocuments                   VendorKycDocument[]
  address                        VendorAddress?
  payoutMethod                   VendorPayoutMethod?
  agreementAcceptance            VendorAgreementAcceptance?
  products                       Product[]
  orderSplits                    OrderVendor[]
  deliveryRules                  DeliveryRule[]
  membershipInvoices             MembershipInvoice[]
  coupons                        VendorCoupon[]
  promoBanners                   VendorPromoBanner[]

  @@index([status, onboardingStep])
  @@index([sellerType, status])
  @@index([subscriptionStatus, subscriptionGracePeriodEndsAt])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([storeSlug])
}

model VendorCoupon {
  id                   String              @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId      String              @db.ObjectId
  code                 String
  discountType         CouponDiscountType
  discountValue        Int
  isActive             Boolean             @default(true)
  appliesToAllProducts Boolean             @default(true)
  productIds           String[]            @default([]) @db.ObjectId
  startsAt             DateTime?
  expiresAt            DateTime?
  maxUses              Int?
  usedCount            Int                 @default(0)
  minOrderAmount       Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  vendorProfile        VendorProfile       @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  promoBanners         VendorPromoBanner[]

  @@unique([vendorProfileId, code])
  @@index([vendorProfileId, isActive])
}

model VendorPromoBanner {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId String        @db.ObjectId
  title           String
  subtitle        String?
  imageUrl        String
  couponId        String?       @db.ObjectId
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  coupon          VendorCoupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([vendorProfileId, isActive, sortOrder])
}

model VendorKycDocument {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId  String          @db.ObjectId
  documentType     KycDocumentType
  documentUrl      String
  selfieWithIdUrl  String?
  reviewStatus     ReviewStatus    @default(PENDING)
  reviewedByUserId String?         @db.ObjectId
  reviewedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  vendorProfile    VendorProfile   @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@unique([vendorProfileId, documentType])
  @@index([vendorProfileId, reviewStatus])
}

model VendorAddress {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId   String        @unique @db.ObjectId
  addressLine1      String
  city              String
  country           String
  postalCode        String
  proofOfAddressUrl String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  vendorProfile     VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
}

model VendorPayoutMethod {
  id                  String           @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId     String           @unique @db.ObjectId
  method              PayoutMethodType
  accountName         String?
  accountNumberOrIban String?
  bankName            String?
  stripeEmail         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  vendorProfile       VendorProfile    @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
}

model VendorAgreementAcceptance {
  id                       String        @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId          String        @unique @db.ObjectId
  agreedToVendorTerms      Boolean
  agreedToMembershipPolicy Boolean
  agreedToCommissionPolicy Boolean
  agreedToDisputePolicy    Boolean
  agreedToDeliveryRules    Boolean
  acceptedAt               DateTime
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  vendorProfile            VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
}

model Category {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String     @unique
  /// Optional Pashto / Dari names: { "ps": { "name" }, "fa-AF": { "name" } }
  translations Json?
  parentId     String?    @db.ObjectId
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  @@index([parentId, isActive])
}

model Product {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId String                @db.ObjectId
  categoryId      String                @db.ObjectId
  name            String
  slug            String
  description     String
  /// Optional Pashto / Dari copy: { "ps": { "name", "description" }, "fa-AF": { ... } }
  translations    Json?
  images          String[]
  sku             String?
  currency        String
  priceAmount     Int
  stockQty        Int
  approvalStatus  ProductApprovalStatus @default(DRAFT)
  rejectionReason String?
  isActive        Boolean               @default(true)
  /// Denormalized from non-hidden ProductReview rows for fast catalog reads.
  ratingAverage   Float                 @default(0)
  reviewCount     Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  vendorProfile   VendorProfile         @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  category        Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  variants        ProductVariant[]
  reviews         ProductReview[]

  @@unique([vendorProfileId, slug])
  @@index([vendorProfileId, approvalStatus])
  @@index([categoryId, approvalStatus, isActive])
}

model ProductReview {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  userId    String   @db.ObjectId
  rating    Int
  comment   String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId, isHidden, createdAt])
  @@index([userId, createdAt])
  @@unique([productId, userId])
}

model ProductVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  name        String
  priceAmount Int?
  stockQty    Int      @default(0)
  sku         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model CustomerAddress {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  label        String?
  fullName     String
  phone        String
  addressLine1 String
  city         String
  country      String
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
}

model Cart {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @unique @db.ObjectId
  currency  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId               String   @db.ObjectId
  productId            String   @db.ObjectId
  vendorProfileId      String   @db.ObjectId
  quantity             Int
  currencySnapshot     String
  unitPriceSnapshot    Int
  productNameSnapshot  String
  productImageSnapshot String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  cart                 Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId, vendorProfileId])
}

model Order {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  userId                String?       @db.ObjectId
  guestEmail            String?
  guestTrackingToken    String?
  orderNumber           String        @unique
  status                OrderStatus   @default(CREATED)
  paymentStatus         PaymentStatus @default(UNPAID)
  deliveryMethod        DeliveryMethod?
  currency              String
  subtotalAmount        Int
  deliveryAmount        Int
  discountAmount        Int
  grandTotalAmount      Int
  shippingFullName      String
  shippingPhone         String
  shippingAddressLine1  String
  shippingCity          String
  shippingCountry       String
  shippingPostalCode    String
  /// Unique when set — enforced via sparse MongoDB index (see scripts/fix-order-stripe-payment-intent-index.ts).
  /// Prisma @unique is not used because many orders omit this field and MongoDB non-sparse unique indexes only allow one missing value.
  stripePaymentIntentId String?
  cancelledAt           DateTime?
  cancellationReason    String?
  cancelledByRole       OrderCancelledByRole?
  cancelledByUserId     String?               @db.ObjectId
  createdAt             DateTime              @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorOrders          OrderVendor[]
  consolidationBatch    ConsolidationBatch?
  outboundShipment      ConsolidatedOutboundShipment?
  inboundShipments      VendorInboundShipment[]
  refundCases           RefundCase[]

  @@index([userId, createdAt])
  @@index([status, paymentStatus])
  @@index([guestEmail, createdAt])
  @@index([guestTrackingToken])
}

model OrderVendor {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  orderId          String            @db.ObjectId
  vendorProfileId  String            @db.ObjectId
  status           VendorOrderStatus @default(NEW)
  deliveryMethod   DeliveryMethod?
  /** Customer-facing carrier tracking (Express / direct ship). Standard uses outboundShipment.trackingRef. */
  trackingRef      String?
  deliveredAt      DateTime?
  currency         String
  subtotalAmount   Int
  deliveryAmount   Int
  discountAmount   Int
  grandTotalAmount Int
  couponCode       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorProfile    VendorProfile     @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)
  inboundShipment  VendorInboundShipment?
  items            OrderItem[]

  @@unique([orderId, vendorProfileId])
  @@index([vendorProfileId, status, createdAt])
}

model ConsolidationBatch {
  id                    String                   @id @default(auto()) @map("_id") @db.ObjectId
  orderId               String                   @unique @db.ObjectId
  status                ConsolidationBatchStatus @default(OPEN)
  expectedVendorCount   Int
  receivedVendorCount   Int                      @default(0)
  readyToConsolidateAt  DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  order                 Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inboundShipments      VendorInboundShipment[]
  outboundShipment      ConsolidatedOutboundShipment?

  @@index([status, updatedAt])
}

model VendorInboundShipment {
  id                   String               @id @default(auto()) @map("_id") @db.ObjectId
  orderId              String               @db.ObjectId
  orderVendorId        String               @unique @db.ObjectId
  consolidationBatchId String               @db.ObjectId
  vendorProfileId      String               @db.ObjectId
  status               InboundShipmentStatus @default(PENDING_SHIPMENT)
  trackingRef          String?
  shippedAt            DateTime?
  receivedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  order                Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderVendor          OrderVendor          @relation(fields: [orderVendorId], references: [id], onDelete: Cascade)
  consolidationBatch   ConsolidationBatch   @relation(fields: [consolidationBatchId], references: [id], onDelete: Cascade)

  @@index([consolidationBatchId, status, updatedAt])
  @@index([vendorProfileId, status, createdAt])
}

model ConsolidatedOutboundShipment {
  id                    String                @id @default(auto()) @map("_id") @db.ObjectId
  orderId               String                @unique @db.ObjectId
  consolidationBatchId  String                @unique @db.ObjectId
  status                OutboundShipmentStatus @default(CONSOLIDATED)
  trackingRef           String?
  consolidatedAt        DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  order                 Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  consolidationBatch    ConsolidationBatch    @relation(fields: [consolidationBatchId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model OrderItem {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  orderVendorId   String       @db.ObjectId
  productId       String       @db.ObjectId
  variantId       String?      @db.ObjectId
  variantName     String?
  quantity        Int
  currency        String
  unitPriceAmount Int
  lineTotalAmount Int
  productName     String
  productImage    String?
  productSku      String?
  vendorProfileId String       @db.ObjectId
  categoryId      String       @db.ObjectId
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  orderVendor     OrderVendor  @relation(fields: [orderVendorId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  refundCases     RefundCase[]

  @@index([orderVendorId, productId])
  @@index([vendorProfileId, createdAt])
}

model PaymentTransaction {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String                   @db.ObjectId
  provider          PaymentProvider
  providerEventId   String
  providerPaymentId String
  eventType         String
  amount            Int
  currency          String
  status            PaymentTransactionStatus
  rawPayload        Json
  processedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([provider, providerEventId])
  @@index([orderId, provider, createdAt])
}

model CommissionLedger {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId          String   @db.ObjectId
  orderVendorId    String   @unique @db.ObjectId
  vendorProfileId  String   @db.ObjectId
  rateBps          Int
  baseAmount       Int
  commissionAmount Int
  currency         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([vendorProfileId, createdAt])
}

model VendorLedgerEntry {
  id                   String                @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId      String                @db.ObjectId
  orderId              String?               @db.ObjectId
  orderVendorId        String?               @db.ObjectId
  refundCaseId         String?               @db.ObjectId
  paymentTransactionId String?               @db.ObjectId
  payoutId             String?               @db.ObjectId
  bucket               LedgerBucket
  entryType            VendorLedgerEntryType
  amount               Int
  currency             String
  description          String?
  createdAt            DateTime              @default(now())

  @@index([vendorProfileId, bucket, createdAt])
  @@index([orderVendorId, entryType])
  @@index([refundCaseId])
}

model Payout {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId String       @db.ObjectId
  orderVendorId   String       @unique @db.ObjectId
  amount          Int
  currency        String
  status          PayoutStatus @default(ON_HOLD)
  holdUntil       DateTime
  releasedAt      DateTime?
  sentAt          DateTime?
  failureReason   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([vendorProfileId, status, holdUntil])
}

model DeliveryRule {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  method          DeliveryMethod
  scope           DeliveryRuleScope
  vendorProfileId String?            @db.ObjectId
  countryCode     String?
  priceModel      DeliveryPriceModel
  baseFeeAmount   Int
  transactionFeeAmountMinor Int?
  commissionRateBps Int?
  perKmRateAmount Int?
  freeAboveAmount Int?
  etaMinDays      Int
  etaMaxDays      Int
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  vendorProfile   VendorProfile?     @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([method, scope, countryCode, isActive])
  @@index([vendorProfileId, method, isActive])
}

model MembershipInvoice {
  id                   String                  @id @default(auto()) @map("_id") @db.ObjectId
  vendorProfileId      String                  @db.ObjectId
  periodStart          DateTime
  periodEnd            DateTime
  dueAt                DateTime
  amount               Int
  currency             String
  status               MembershipInvoiceStatus @default(PENDING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeInvoiceId      String?
  stripePaymentId      String?
  stripeEventId        String?
  failureCode          String?
  failureReason        String?
  attemptedAt          DateTime?
  invoiceHostedUrl     String?
  paidAt               DateTime?
  waivedReason         String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  vendorProfile        VendorProfile           @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@unique([vendorProfileId, periodStart, periodEnd])
  @@index([stripeInvoiceId])
  @@index([status, dueAt])
  @@index([vendorProfileId, createdAt])
  @@index([stripeSubscriptionId, periodStart])
}

model RefundCase {
  id                  String           @id @default(auto()) @map("_id") @db.ObjectId
  orderId             String           @db.ObjectId
  orderItemId         String           @db.ObjectId
  activeOrderItemKey  String?          @unique
  customerUserId      String           @db.ObjectId
  vendorProfileId     String           @db.ObjectId
  reason              String
  description         String?
  requestedAmount     Int
  status              RefundCaseStatus @default(REQUESTED)
  vendorExplanation   String?
  vendorResponseDueAt DateTime?
  escalatedAt         DateTime?
  finalDecisionAt     DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  order               Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem           OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  customerUser        User             @relation(fields: [customerUserId], references: [id], onDelete: Cascade)
  evidences           RefundEvidence[]
  decision            RefundDecision?
  messages            CaseMessage[]

  @@index([vendorProfileId, status, vendorResponseDueAt])
  @@index([customerUserId, createdAt])
}

model RefundEvidence {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  refundCaseId String     @db.ObjectId
  actorUserId  String?    @db.ObjectId
  actorRole    Role
  fileUrl      String?
  note         String?
  createdAt    DateTime   @default(now())
  refundCase   RefundCase @relation(fields: [refundCaseId], references: [id], onDelete: Cascade)

  @@index([refundCaseId, createdAt])
}

model RefundDecision {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  refundCaseId    String             @unique @db.ObjectId
  decisionType    RefundDecisionType
  approvedAmount  Int
  reason          String?
  stripeRefundId            String?
  stripeRefundStatus        String?
  stripeRefundFailureCode   String?
  stripeRefundFailureReason String?
  stripeRefundAttemptedAt   DateTime?
  decidedByUserId String             @db.ObjectId
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  refundCase      RefundCase         @relation(fields: [refundCaseId], references: [id], onDelete: Cascade)

  @@index([decidedByUserId, createdAt])
  @@index([stripeRefundId])
}

model CaseMessage {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  refundCaseId  String     @db.ObjectId
  senderUserId  String     @db.ObjectId
  senderRole    Role
  message       String
  attachmentUrl String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  refundCase    RefundCase @relation(fields: [refundCaseId], references: [id], onDelete: Cascade)
  senderUser    User       @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([refundCaseId, createdAt])
}

enum GiftRequestStatus {
  SUBMITTED
  REVIEWING
  AWAITING_PAYMENT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum GiftRequestPaymentMethod {
  STRIPE
  OFFLINE
}

model GiftRequest {
  id                    String            @id @default(auto()) @map("_id") @db.ObjectId
  requestNumber         String            @unique
  userId                String?           @db.ObjectId
  senderName            String
  senderEmail           String
  senderPhone           String
  recipientName         String
  recipientPhone        String
  recipientCity         String
  recipientProvince     String?
  recipientAddress      String
  occasion              String?
  preferredDeliveryDate String?
  /// When set to "DRESS", the dress* fields below describe the requested item.
  itemType              String?
  dressColor            String?
  dressSize             String?
  dressSleeveType       String?
  dressLength           String?
  dressFitting          String?
  dressTexture          String?
  dressForMale          Boolean           @default(false)
  dressForFemale        Boolean           @default(false)
  preparationNotes      String
  deliveryInstructions  String
  budgetNote            String?
  imageUrls             String[]          @default([])
  videoUrls             String[]          @default([])
  quoteAmountMinor      Int?
  quoteCurrency         String?
  quoteNote             String?
  quoteImageUrl         String?
  quoteSentAt           DateTime?
  paidAt                DateTime?
  paidAmountMinor       Int?
  paymentMethod         GiftRequestPaymentMethod?
  offlinePaymentNote    String?
  stripePaymentIntentId String?
  status                GiftRequestStatus @default(SUBMITTED)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([senderEmail, createdAt])
}

model PlatformSettings {
  id                        String   @id @map("_id")
  transactionFeeAmountMinor Int      @default(399)
  availableLocales          String[] @default(["en", "ps", "fa-AF"])
  availableCurrencies       String[] @default(["USD", "EUR", "GBP", "CAD"])
  /// Mandawee's own warehouse pickup address, used as the delivery origin for
  /// platform (1P) items priced per kilometer.
  warehouseAddressLine1     String?
  warehouseCity             String?
  warehouseCountry          String?
  warehousePostalCode       String?
  updatedAt                 DateTime @updatedAt
  updatedByUserId           String?  @db.ObjectId
}

enum HawalaTransferStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  FAILED
  CANCELLED
}

model HawalaExchangeRate {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  /// ISO currency code, e.g. "USD", "AFN".
  currency        String   @unique
  /// Value of 1 unit of `currency` expressed in AFN (Afghan Afghani).
  rateToAfn       Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedByUserId String?  @db.ObjectId
}

model HawalaTransfer {
  id                    String               @id @default(auto()) @map("_id") @db.ObjectId
  transferNumber        String               @unique
  userId                String?              @db.ObjectId

  senderName            String
  senderPhone           String
  senderEmail           String?
  senderCountry         String
  senderAddress         String
  senderBankName        String
  senderAccountNumber   String

  receiverName          String
  receiverPhone         String
  receiverCountry       String
  receiverAddress       String
  receiverBankName      String
  receiverAccountNumber String

  sendAmountMinor       Int
  sendCurrency          String
  receiveAmountMinor    Int
  receiveCurrency       String
  /// Snapshot of the receiveCurrency-per-sendCurrency rate used at submission time.
  exchangeRate          Float
  note                  String?

  status                HawalaTransferStatus @default(PENDING)
  adminNote             String?

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user                  User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([senderPhone, createdAt])
  @@index([receiverPhone, createdAt])
}

enum HomeBannerPlacement {
  HERO
  SECTION
  DUO
}

model HomeBanner {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  subtitle       String?
  placement      HomeBannerPlacement   @default(HERO)
  imageUrl       String
  imageMobileUrl String?
  href           String
  ctaLabel       String?
  isActive       Boolean             @default(true)
  sortOrder      Int                 @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([placement, isActive, sortOrder])
  @@index([startsAt, expiresAt])
}
