{
  "name": "onlinemandawee",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx prisma generate && next dev",
    "dev:clean": "rm -rf .next && npx prisma generate && next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:push": "dotenv -e .env.local -- prisma db push && dotenv -e .env.local -- node --import tsx scripts/fix-order-stripe-payment-intent-index.ts",
    "prisma:fix-payment-intent-index": "dotenv -e .env.local -- node --import tsx scripts/fix-order-stripe-payment-intent-index.ts",
    "resend-order-notifications": "dotenv -e .env.local -- node --import tsx scripts/resend-order-notifications.ts",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "seed:admin": "node --import tsx scripts/seed-admin.ts",
    "seed:categories": "dotenv -e .env.local -- node --import tsx scripts/seed-storefront-categories.ts",
    "seed:baby-care": "dotenv -e .env.local -- node --import tsx scripts/seed-baby-care-products.ts",
    "categories:consolidate-baby-care": "dotenv -e .env.local -- node --import tsx scripts/consolidate-baby-care-category.ts",
    "realtime:dev": "npm run dev --prefix realtime",
    "realtime:build": "npm run build --prefix realtime",
    "worker:refund-overdue-escalation": "node --import tsx scripts/refund-overdue-escalation-worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.6.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^7.0.12",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
